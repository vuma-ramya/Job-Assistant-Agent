# Copy this to .env and fill in your values
# Never commit .env to GitHub!

# LLM Provider — pick ONE
OPENAI_API_KEY=sk-...              # OpenAI GPT-4o
# GROQ_API_KEY=gsk_...            # Groq (free, fast Llama3 — great for testing)

# Which provider to use: "openai" or "groq"
LLM_PROVIDER=openai

# Model name
# OpenAI: gpt-4o-mini (cheap) or gpt-4o
# Groq:   llama3-8b-8192 (free) or llama3-70b-8192
LLM_MODEL=gpt-4o-mini

# App settings
APP_HOST=0.0.0.0
APP_PORT=8000
